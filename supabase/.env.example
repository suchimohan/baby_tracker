# Copy this file to supabase/.env and fill in your values.
# supabase/.env is gitignored — never commit the real file.

# Apple Sign-In secret (production only — not needed for simulator testing)
# Format: KEY_ID:TEAM_ID:base64(contents-of-.p8-file)
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# Google OAuth secret (web client secret from Google Cloud Console)
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
